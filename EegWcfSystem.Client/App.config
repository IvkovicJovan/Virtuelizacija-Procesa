<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <appSettings>
    <add key="EegRoot" value="EEG" />
    <!-- 0 = normalno. Stavi npr. 10 za simulaciju prekida poslije 10 poslatih redova. -->
    <add key="SimulateBreakAfterRows" value="0" />
  </appSettings>

  <system.serviceModel>
    <bindings>
      <netTcpBinding>
        <binding name="StreamBinding"
                 transferMode="Streamed"
                 maxReceivedMessageSize="2147483647"
                 maxBufferSize="65536"
                 sendTimeout="00:10:00"
                 receiveTimeout="00:10:00"
                 openTimeout="00:01:00"
                 closeTimeout="00:01:00">
          <security mode="None" />
        </binding>
      </netTcpBinding>
    </bindings>

    <client>
      <endpoint name="EegEndpoint"
                address="net.tcp://localhost:9000/EegService"
                binding="netTcpBinding"
                bindingConfiguration="StreamBinding"
                contract="EegWcfSystem.Common.Contracts.IEegService" />
    </client>
  </system.serviceModel>
</configuration>
